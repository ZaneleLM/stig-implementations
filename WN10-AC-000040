DESCRIPTION
This script automates the configuration of the "Enable password complexity" policy.

#Requires -RunAsAdministrator

[CmdletBinding(SupportsShouldProcess)]
param ()

$STIG_ID  = "WN10-AC-000040"
$LOG_FILE = "$env:SystemRoot\Logs\STIG-Remediation-$STIG_ID.log"

# Ensure log directory exists
if (-not (Test-Path "$env:SystemRoot\Logs")) {
    New-Item -ItemType Directory -Path "$env:SystemRoot\Logs" -Force | Out-Null
}

function Write-Log {
    param(
        [string]$Message,
        [string]$Level = "INFO"
    )
    $entry = "[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] [$Level] $Message"
    Write-Host $entry
    $entry | Out-File -FilePath $LOG_FILE -Append -Encoding UTF8
}


# 1. Export current local security policy and read complexity setting
#    PasswordComplexity = 1 means enabled (compliant)
#    PasswordComplexity = 0 means disabled (non-compliant)

Write-Log "Starting remediation for $STIG_ID - Enable Password Complexity"

$exportFile = "$env:TEMP\secpol_export_$STIG_ID.cfg"

try {
    secedit /export /cfg $exportFile /quiet | Out-Null
    if (-not (Test-Path $exportFile)) {
        throw "secedit export file not found after export."
    }
} catch {
    Write-Log "Failed to export security policy: $($_.Exception.Message)" "ERROR"
    exit 1
}

$currentValue = $null
$line = Get-Content $exportFile | Where-Object { $_ -match "PasswordComplexity" }
if ($line -match "=\s*(\d+)") {
    $currentValue = [int]$Matches[1]
}
Remove-Item $exportFile -Force -ErrorAction SilentlyContinue

Write-Log "Current PasswordComplexity : $(if ($null -eq $currentValue) { 'Unable to read' } else { $currentValue })"
Write-Log "Required PasswordComplexity: 1 (Enabled)"


# 2. Check compliance 

if ($currentValue -eq 1) {
    Write-Log "Password complexity is already enabled. No changes needed."
    exit 0
}


# 3. Apply the fix via secedit INF template

Write-Log "Applying fix: enabling password complexity ..."

$infFile = "$env:TEMP\secpol_complexity_$STIG_ID.inf"
$sdbFile = "$env:TEMP\secpol_complexity_$STIG_ID.sdb"
$logFile = "$env:TEMP\secpol_complexity_$STIG_ID.log"

$infContent = @"
[Unicode]
Unicode=yes
[System Access]
PasswordComplexity = 1
[Version]
signature="`$CHICAGO`$"
Revision=1
"@

if ($PSCmdlet.ShouldProcess("Local Security Policy", "Enable PasswordComplexity")) {
    try {
        $infContent | Out-File -FilePath $infFile -Encoding Unicode -Force

        secedit /configure /db $sdbFile /cfg $infFile /log $logFile /quiet

        if ($LASTEXITCODE -ne 0) {
            Write-Log "secedit /configure failed (exit code $LASTEXITCODE). Check $logFile for details." "ERROR"
            exit 1
        }

        Write-Log "secedit /configure succeeded."
    } catch {
        Write-Log "Exception applying security policy: $($_.Exception.Message)" "ERROR"
        exit 1
    } finally {
        Remove-Item $infFile -Force -ErrorAction SilentlyContinue
        Remove-Item $sdbFile -Force -ErrorAction SilentlyContinue
        Remove-Item $logFile -Force -ErrorAction SilentlyContinue
    }
}


# 4. Verify the change was applied

Write-Log "Verifying remediation ..."

$verifyFile = "$env:TEMP\secpol_verify_$STIG_ID.cfg"

try {
    secedit /export /cfg $verifyFile /quiet | Out-Null

    $newValue = $null
    $verifyLine = Get-Content $verifyFile | Where-Object { $_ -match "PasswordComplexity" }
    if ($verifyLine -match "=\s*(\d+)") {
        $newValue = [int]$Matches[1]
    }
    Remove-Item $verifyFile -Force -ErrorAction SilentlyContinue

    if ($newValue -eq 1) {
        Write-Log "VERIFICATION PASSED - PasswordComplexity is now enabled (value: $newValue)."
        exit 0
    } else {
        Write-Log "VERIFICATION FAILED - PasswordComplexity value is '$newValue' (expected 1)." "ERROR"
        exit 1
    }
} catch {
    Write-Log "Failed to verify password complexity setting: $($_.Exception.Message)" "ERROR"
    exit 1
}

# Verify
secedit /export /cfg "$env:TEMP\check.cfg" /quiet; Get-Content "$env:TEMP\check.cfg" | Select-String "PasswordComplexity"
