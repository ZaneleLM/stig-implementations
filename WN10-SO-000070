WN10-SO-000070

DESCRIPTION
This script automates the configuration of the "Screen lock after 15 minutes of inactivity" policy.

Requires -RunAsAdministrator

[CmdletBinding(SupportsShouldProcess)]
param (
    [int]$InactivityTimeoutSecs = 900   # 900 seconds = 15 minutes (STIG maximum)
)

$STIG_ID  = "WN10-SO-000070"
$LOG_FILE = "$env:SystemRoot\Logs\STIG-Remediation-$STIG_ID.log"

$REG_PATH = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\System"
$REG_NAME = "InactivityTimeoutSecs"

# Ensure log directory exists
if (-not (Test-Path "$env:SystemRoot\Logs")) {
    New-Item -ItemType Directory -Path "$env:SystemRoot\Logs" -Force | Out-Null
}

function Write-Log {
    param(
        [string]$Message,
        [string]$Level = "INFO"
    )
    $entry = "[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] [$Level] $Message"
    Write-Host $entry
    $entry | Out-File -FilePath $LOG_FILE -Append -Encoding UTF8
}


# 1. Read current registry value

Write-Log "Starting remediation for $STIG_ID - Screen Lock Inactivity Timeout"

$currentValue = $null
try {
    if (Test-Path $REG_PATH) {
        $currentValue = (Get-ItemProperty -Path $REG_PATH -Name $REG_NAME -ErrorAction SilentlyContinue).$REG_NAME
    }
} catch {
    Write-Log "Failed to read registry value: $($_.Exception.Message)" "ERROR"
    exit 1
}

Write-Log "Registry path  : $REG_PATH"
Write-Log "Registry value : $REG_NAME"
Write-Log "Current value  : $(if ($null -eq $currentValue) { 'Not set' } else { "$currentValue seconds" })"
Write-Log "Required value : $InactivityTimeoutSecs seconds ($(($InactivityTimeoutSecs / 60)) minutes) or less"


# 2. Check compliance - exit early if already compliant
#    Compliant = value is set, greater than 0, and <= 900

if ($null -ne $currentValue -and $currentValue -gt 0 -and $currentValue -le $InactivityTimeoutSecs) {
    Write-Log "Inactivity timeout is already compliant (value: $currentValue seconds). No changes needed."
    exit 0
}


# 3. Apply the fix via registry
-
Write-Log "Applying fix: setting $REG_NAME to $InactivityTimeoutSecs ..."

if ($PSCmdlet.ShouldProcess($REG_PATH, "Set $REG_NAME to $InactivityTimeoutSecs")) {
    try {
        # Create the key if it doesn't exist
        if (-not (Test-Path $REG_PATH)) {
            New-Item -Path $REG_PATH -Force | Out-Null
            Write-Log "Registry path did not exist - created: $REG_PATH"
        }

        Set-ItemProperty -Path $REG_PATH -Name $REG_NAME -Value $InactivityTimeoutSecs -Type DWord -Force
        Write-Log "Registry value set successfully."
    } catch {
        Write-Log "Failed to set registry value: $($_.Exception.Message)" "ERROR"
        exit 1
    }
}


# 4. Verify the change was applied

Write-Log "Verifying remediation ..."

try {
    $newValue = (Get-ItemProperty -Path $REG_PATH -Name $REG_NAME -ErrorAction Stop).$REG_NAME

    if ($null -ne $newValue -and $newValue -gt 0 -and $newValue -le $InactivityTimeoutSecs) {
        Write-Log "VERIFICATION PASSED - $REG_NAME is now $newValue seconds ($(($newValue / 60)) minutes)."
        exit 0
    } else {
        Write-Log "VERIFICATION FAILED - $REG_NAME value is '$newValue' (expected 1-$InactivityTimeoutSecs)." "ERROR"
        exit 1
    }
} catch {
    Write-Log "Failed to verify registry value: $($_.Exception.Message)" "ERROR"
    exit 1
}
